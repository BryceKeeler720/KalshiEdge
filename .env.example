KALSHI_API_KEY_ID=               # RSA API key ID from Kalshi dashboard
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem
KALSHI_ENV=demo                  # "demo" or "prod"
DRY_RUN=true                     # "true" = forecast only, no orders
ANTHROPIC_API_KEY=
TWOSIGNAL_API_KEY=
TWOSIGNAL_BASE_URL=http://localhost:3010
NEWSAPI_KEY=                     # Optional — 500 free requests/day
TELEGRAM_BOT_TOKEN=              # Optional — leave blank to disable alerts
TELEGRAM_CHAT_ID=
BANKROLL_USD=100
MIN_EDGE_THRESHOLD=0.08
KELLY_FRACTION=0.25
MAX_POSITION_PCT=0.05
MAX_EXPOSURE_PCT=0.50
MAX_CONCURRENT_POSITIONS=12
CYCLE_INTERVAL_SECONDS=1800
MAX_FORECASTS_PER_CYCLE=5
